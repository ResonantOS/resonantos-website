---
import '../styles/global.css';
import SiteNav from './SiteNav.astro';

const {
	title = 'ResonantOS - ResonantDAO Membership and Governance',
	description = 'ResonantOS is moving into a DAO-first architecture built around official non-transferable membership credentials, contribution reputation, and community governance.',
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://resonantos.com" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased overflow-x-hidden">
		<div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_20%_10%,rgba(16,185,129,0.16),transparent_28%),radial-gradient(circle_at_85%_20%,rgba(217,119,6,0.12),transparent_30%),linear-gradient(135deg,#09090b,#18181b_55%,#050505)]"></div>
		<SiteNav />
		<main class="relative z-10 pt-28">
			<slot />
		</main>
		<footer class="relative z-10 border-t border-white/10 px-4 py-12 sm:px-6 lg:px-8">
			<div class="mx-auto flex max-w-6xl flex-col gap-6 text-sm text-zinc-500 md:flex-row md:items-center md:justify-between">
				<div>
					<p class="text-lg font-medium text-zinc-100">Resonant<span class="text-emerald-400">OS</span></p>
					<p>Governed through ResonantDAO. Built by creators, for creators.</p>
				</div>
				<div class="flex flex-wrap gap-4">
					<a class="hover:text-zinc-100 transition-colors" href="/membership">Membership</a>
					<a class="hover:text-zinc-100 transition-colors" href="/dao">DAO</a>
					<a class="hover:text-zinc-100 transition-colors" href="/symbiotic-license">Licence</a>
					<a class="hover:text-zinc-100 transition-colors" href="https://augmentedmind.co/" target="_blank" rel="noopener noreferrer">Blog</a>
				</div>
			</div>
		</footer>
	</body>
</html>

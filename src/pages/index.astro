---
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
// ResonantOS Marketing Site - Immersive Design
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>ResonantOS - AI Agent Operating System</title>
		<meta name="description" content="ResonantOS is an app for running AI agents with memory, tools, add-ons, human control, and a DAO-backed co-ownership model." />
		
		<!-- Open Graph -->
		<meta property="og:title" content="ResonantOS - AI Agent Operating System" />
		<meta property="og:description" content="ResonantOS is an app for running AI agents with memory, tools, add-ons, human control, and a DAO-backed co-ownership model." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://resonantos.com" />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="ResonantOS - AI Agent Operating System" />
		<meta name="twitter:description" content="ResonantOS is an app for running AI agents with memory, tools, add-ons, human control, and a DAO-backed co-ownership model." />
		
		<!-- Fonts: DM Sans for brand consistency -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
	</head>
	
	<body class="bg-zinc-950 text-zinc-100 antialiased overflow-x-hidden">
		<!-- Animated Background -->
		<div id="background-container" class="fixed inset-0 z-0 overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-zinc-950 via-zinc-900 to-zinc-950"></div>
			
			<!-- Animated gradient orbs -->
			<div class="gradient-orb gradient-orb-1"></div>
			<div class="gradient-orb gradient-orb-2"></div>
			<div class="gradient-orb gradient-orb-3"></div>
			<div class="gradient-orb gradient-orb-4"></div>
			
			<!-- Noise overlay -->
			<div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
		</div>

		<!-- Fixed Viewport Blur Zones -->
		<div id="blur-zone-top" class="blur-zone blur-zone-top"></div>
		<div id="blur-zone-bottom" class="blur-zone blur-zone-bottom"></div>

		<!-- Navigation -->
		<SiteNav />

		<!-- Giant Hero Logo -->
		<section id="hero-section" class="h-screen relative flex items-center justify-center overflow-hidden">
			<div id="hero-logo" class="text-center select-none w-full px-4" style="filter: blur(0.5px);">
				<h1 class="hero-text leading-none tracking-tight">
					<span class="font-light text-white">Resonant</span><span class="font-bold text-emerald-400">OS</span>
				</h1>
				<p class="tagline-text text-zinc-400 mt-6 font-light" style="filter: blur(0px);">
					The operating app for your AI agent team
				</p>
			</div>
			
			<!-- Scroll indicator -->
			<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
				<svg class="w-6 h-6 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
				</svg>
			</div>
		</section>

		<!-- Scroll Content Container -->
		<div id="scroll-content" class="relative z-20">

		<!-- What is ResonantOS -->
		<section id="what-is" class="content-section py-12 scroll-mt-[25vh]">
			<div class="glass-banner text-left">
				<div class="banner-content prose-content">
					<h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-8 tracking-tight">What is <span class="gradient-text">ResonantOS</span>?</h2>
					<div class="space-y-6 text-lg text-zinc-300 leading-relaxed">
						<p>
							ResonantOS is an <strong class="color-primary">AI agent operating app</strong>: a workspace where personal AI agents can remember context, use tools, run workflows, and stay under human control.
						</p>
						<ul class="space-y-3 text-zinc-300">
							<li>• <strong class="color-secondary">Agent workspace</strong>: Run coordinated AI agents across tasks, tools, and projects</li>
							<li>• <strong class="color-secondary">Persistent context</strong>: Keep memory, preferences, project state, and creative direction available over time</li>
							<li>• <strong class="color-secondary">Custom add-ons</strong>: Extend the app with new tools, workflows, connectors, and community-built capabilities</li>
							<li>• <strong class="color-secondary">Human control</strong>: Keep approval, visibility, and safety checks around work that matters</li>
						</ul>
						<p class="text-xl font-semibold gradient-text mt-8">
							Not just chat. A customizable operating layer for working with AI agents.
						</p>
						<p>
							ResonantDAO supports the ownership model behind ResonantOS. Community membership, NFTs, and co-ownership are important, but they are the governance layer around the product. The product itself is ResonantOS: the app people use to run AI-assisted work.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- The ResonantOS Platform -->
		<section id="economy" class="content-section py-12 scroll-mt-[25vh]">
			<div class="glass-banner text-left">
				<div class="banner-content prose-content">
					<h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-8 tracking-tight">A Customizable <span class="gradient-text">Agent</span> Platform</h2>
					<div class="space-y-6 text-lg text-zinc-300 leading-relaxed">
						<p>
							ResonantOS is designed to be extended. Users should not be locked into one fixed set of agents, one fixed interface, or one fixed workflow. The app becomes more useful as people add the exact capabilities they need.
						</p>
						
						<div class="component-card my-8">
							<h3 class="text-xl font-semibold mb-4 text-zinc-100">How it works:</h3>
							<ul class="space-y-4 text-zinc-300">
								<li class="flex items-start">
									<span class="color-primary mr-3 mt-1">→</span>
									<span><strong class="color-secondary">Install add-ons.</strong> Add tools, connectors, skills, dashboards, and workflows that match the way you work.</span>
								</li>
								<li class="flex items-start">
									<span class="color-primary mr-3 mt-1">→</span>
									<span><strong class="color-secondary">Build your own.</strong> Developers and advanced users can create custom add-ons for personal workflows or shared community use.</span>
								</li>
								<li class="flex items-start">
									<span class="color-primary mr-3 mt-1">→</span>
									<span><strong class="color-secondary">Share through the community.</strong> Community members can publish useful add-ons so others can inspect, improve, and reuse them.</span>
								</li>
								<li class="flex items-start">
									<span class="color-primary mr-3 mt-1">→</span>
									<span><strong class="color-secondary">Keep control.</strong> Add-ons should run inside clear permissions, safety rules, and user approval flows.</span>
								</li>
							</ul>
						</div>
						
						<p>
							This makes ResonantOS closer to an operating environment than a single AI product. The app provides the base system; add-ons let the community expand what the system can do.
						</p>
						
						<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
							<div class="emergent-card text-center">
								<div class="mb-3 flex justify-center">
									<svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
									</svg>
								</div>
								<h4 class="font-semibold color-primary mb-2">Official Originals</h4>
								<p class="text-sm text-zinc-400">Trusted community releases can be identified and verified</p>
							</div>
							<div class="emergent-card text-center">
								<div class="mb-3 flex justify-center">
									<svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
								</div>
								<h4 class="font-semibold color-primary mb-2">Custom Add-ons</h4>
								<p class="text-sm text-zinc-400">Users can extend the app with their own workflows</p>
							</div>
							<div class="emergent-card text-center">
								<div class="mb-3 flex justify-center">
									<svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
									</svg>
								</div>
								<h4 class="font-semibold color-primary mb-2">DAO Co-ownership</h4>
								<p class="text-sm text-zinc-400">The community can help shape the platform it uses</p>
							</div>
						</div>
						
						<p class="mt-8 text-zinc-400 italic">
							ResonantDAO provides the co-ownership and membership model around the app. The detailed DAO registration flow lives at <a href="https://resonantdao.com/" class="color-primary hover:underline">ResonantDAO.com</a>.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Comparison Table -->
		<section class="py-20 px-4 sm:px-6 lg:px-8">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl sm:text-5xl font-bold mb-6 tracking-tight">ResonantOS vs. Other AI Agent Apps</h2>
				<p class="text-xl text-zinc-400 mb-12 max-w-3xl">
					<strong class="text-zinc-200">Most AI tools start with a prompt box.</strong> ResonantOS starts with the workspace around the agents: memory, add-ons, permissions, shared workflows, and long-term ownership.
				</p>
				
				<div class="grid grid-cols-1 gap-4 mb-8">
					<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
						<h3 class="text-sm font-mono text-blue-400 mb-2 flex items-center gap-2"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> App-first</h3>
						<p class="text-zinc-300">a real working environment for AI-assisted projects</p>
					</div>
					<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
						<h3 class="text-sm font-mono text-blue-400 mb-2 flex items-center gap-2"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Add-on native</h3>
						<p class="text-zinc-300">custom capabilities can be built, installed, and shared</p>
					</div>
					<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
						<h3 class="text-sm font-mono text-blue-400 mb-2 flex items-center gap-2"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Human controlled</h3>
						<p class="text-zinc-300">agents work with user approvals, policies, and visibility</p>
					</div>
					<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
						<h3 class="text-sm font-mono text-blue-400 mb-2 flex items-center gap-2"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Community owned</h3>
						<p class="text-zinc-300">the DAO supports co-ownership, contribution, and stewardship</p>
					</div>
				</div>

				<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6 mb-12">
					<p class="text-lg text-zinc-300 mb-4">
						<strong class="text-zinc-100">Think of it as:</strong> a local-first command center where agents, tools, add-ons, and project memory work together instead of living in separate browser tabs and disconnected chat sessions.
					</p>
					<p class="text-sm text-zinc-400 mb-4 italic">
						The DAO is not the headline feature of this page. It is the ownership and trust layer that explains why the platform can be community shaped instead of controlled by a closed vendor.
					</p>
					<div class="space-y-2">
						<p class="text-zinc-400"><strong class="text-zinc-200">For users:</strong> install and configure the AI workspace around your real workflows.</p>
						<p class="text-zinc-400"><strong class="text-zinc-200">For builders:</strong> create add-ons and share them with the community.</p>
					</div>
				</div>

				<!-- Comparison Table -->
				<div class="overflow-x-auto">
					<table class="w-full border-collapse">
						<thead>
							<tr class="border-b border-zinc-800">
								<th class="text-left py-4 px-4 text-sm font-mono text-zinc-400">Feature</th>
								<th class="text-center py-4 px-4 text-sm font-mono text-zinc-400">Typical Agent Apps</th>
								<th class="text-center py-4 px-4 text-sm font-mono text-zinc-400">ResonantOS</th>
							</tr>
						</thead>
						<tbody class="text-sm">
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Primary product focus</td>
								<td class="py-4 px-4 text-center text-amber-500"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> Prompt or task execution</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Agent operating workspace</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Memory and context</td>
								<td class="py-4 px-4 text-center text-amber-500"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> Session based</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Persistent project context</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Customization</td>
								<td class="py-4 px-4 text-center text-amber-500"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> Limited settings</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> User-built add-ons</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Sharing extensions</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> Vendor controlled</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Community add-on ecosystem</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Execution model</td>
								<td class="py-4 px-4 text-center text-amber-500"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> One-off actions</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Coordinated workflows</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Safety and permissions</td>
								<td class="py-4 px-4 text-center text-amber-500"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> App dependent</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Approval and policy layer</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Ownership model</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> Closed vendor</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> DAO-backed co-ownership</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Community participation</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> Feedback only</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Build, share, govern</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Crypto wallet model</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> Usually none</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Later Symbiotic Wallet phase</span></td>
							</tr>
						</tbody>
					</table>
				</div>

				<div class="mt-8 p-6 bg-blue-950/20 border border-blue-800/30 rounded-lg">
					<p class="text-lg text-zinc-200">
						<strong>Bottom line:</strong> ResonantOS is the app for operating AI agents as a customizable working system.
					</p>
					<p class="text-zinc-400 mt-2">
						ResonantDAO explains how co-ownership, membership, and trusted community contribution fit around that app.
					</p>
				</div>
			</div>
		</section>

		<!-- What Makes It Different -->
		<section id="features" class="content-section py-12 scroll-mt-[25vh]">
			<div class="glass-banner text-left">
				<div class="banner-content prose-content" style="max-width: 1200px;">
					<h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-12 tracking-tight">What Makes ResonantOS <span class="gradient-text">Different</span></h2>
				
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						<!-- Feature 1 -->

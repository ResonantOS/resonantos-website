		<!-- GSAP + Lenis scroll animations -->
		<script>
			// @ts-nocheck
			import Lenis from 'lenis';
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			gsap.registerPlugin(ScrollTrigger);

			// Initialize Lenis smooth scroll
			const lenis = new Lenis({
				duration: 1.2,
				easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
			});

			function raf(time) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}
			requestAnimationFrame(raf);

			lenis.on('scroll', ScrollTrigger.update);
			gsap.ticker.add((time) => lenis.raf(time * 1000));
			gsap.ticker.lagSmoothing(0);

			// Hero blur on scroll
			const heroLogo = document.getElementById('hero-logo');
			const heroSection = document.getElementById('hero-section');
			
			if (heroLogo && heroSection) {
				gsap.to(heroLogo, {
					scrollTrigger: {
						trigger: heroSection,
						start: 'top top',
						end: 'bottom top',
						scrub: 1,
					},
					filter: 'blur(20px)',
					opacity: 0.3,
				});
			}

			// ========================================
			// FREE-FLOATING ORBS - Move around the entire page
			// ========================================
			const orbs = document.querySelectorAll('.gradient-orb');
			const vw = window.innerWidth;
			const vh = window.innerHeight;
			
			// Create continuous floating animation for each orb
			function animateOrb(orb, index) {
				// Random duration between 8-15 seconds for variety
				const duration = 8 + Math.random() * 7;
				
				// Generate random target position across the entire viewport
				const getRandomPos = () => ({
					x: (Math.random() - 0.5) * vw * 1.5,
					y: (Math.random() - 0.5) * vh * 2,
					scale: 0.6 + Math.random() * 0.8,
					rotation: Math.random() * 360,
				});
				
				// Create infinite timeline
				const tl = gsap.timeline({ repeat: -1, yoyo: true });
				
				// Add multiple waypoints for organic movement
				for (let i = 0; i < 4; i++) {
					const pos = getRandomPos();
					tl.to(orb, {
						x: pos.x,
						y: pos.y,
						scale: pos.scale,
						rotation: pos.rotation,
						duration: duration,
						ease: 'sine.inOut',
					});
				}
				
				// Offset start time for each orb
				tl.progress(index * 0.25);
			}
			
			orbs.forEach((orb, i) => animateOrb(orb, i));
			
			// Also add scroll-based color transition (emerald → amber as you scroll)
			const orb1 = document.querySelector('.gradient-orb-1');
			const orb2 = document.querySelector('.gradient-orb-2');
			const orb3 = document.querySelector('.gradient-orb-3');
			const orb4 = document.querySelector('.gradient-orb-4');
			
			function addColorTransition(orb, autumnGradient) {
				if (!orb) return;
				gsap.to(orb, {
					scrollTrigger: {
						trigger: document.body,
						start: 'top top',
						end: 'bottom bottom',
						scrub: 2,
					},
					backgroundImage: autumnGradient,
				});
			}
			
			addColorTransition(orb1, 'linear-gradient(135deg, #d97706, #92400e)');
			addColorTransition(orb2, 'linear-gradient(135deg, #b45309, #78350f)');
			addColorTransition(orb3, 'linear-gradient(135deg, #ea580c, #9a3412)');
			addColorTransition(orb4, 'linear-gradient(135deg, #a16207, #713f12)');

			// Content sections reveal
			const sections = document.querySelectorAll('.content-section');
			sections.forEach((section) => {
				ScrollTrigger.create({
					trigger: section,
					start: 'top 80%',
					onEnter: () => section.classList.add('visible'),
				});
			});
		</script>

---
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
// ResonantOS Marketing Site - Immersive Design
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>ResonantOS - DAO Membership and Governance</title>
		<meta name="description" content="ResonantOS is moving into a DAO-first architecture built around official non-transferable membership credentials, contribution reputation, and community governance." />
		
		<!-- Open Graph -->
		<meta property="og:title" content="ResonantOS - DAO Membership and Governance" />
		<meta property="og:description" content="ResonantOS is moving into a DAO-first architecture built around official non-transferable membership credentials, contribution reputation, and community governance." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://resonantos.com" />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="ResonantOS - DAO Membership and Governance" />
		<meta name="twitter:description" content="ResonantOS is moving into a DAO-first architecture built around official non-transferable membership credentials, contribution reputation, and community governance." />
		
		<!-- Fonts: DM Sans for brand consistency -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
	</head>
	
	<body class="bg-zinc-950 text-zinc-100 antialiased overflow-x-hidden">
		<!-- Animated Background -->
		<div id="background-container" class="fixed inset-0 z-0 overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-zinc-950 via-zinc-900 to-zinc-950"></div>
			
			<!-- Animated gradient orbs -->
			<div class="gradient-orb gradient-orb-1"></div>
			<div class="gradient-orb gradient-orb-2"></div>
			<div class="gradient-orb gradient-orb-3"></div>
			<div class="gradient-orb gradient-orb-4"></div>
			
			<!-- Noise overlay -->
			<div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
		</div>

		<!-- Fixed Viewport Blur Zones -->
		<div id="blur-zone-top" class="blur-zone blur-zone-top"></div>
		<div id="blur-zone-bottom" class="blur-zone blur-zone-bottom"></div>

		<!-- Navigation -->
		<SiteNav />

		<!-- Giant Hero Logo -->
		<section id="hero-section" class="h-screen relative flex items-center justify-center overflow-hidden">
			<div id="hero-logo" class="text-center select-none w-full px-4" style="filter: blur(0.5px);">
				<h1 class="hero-text leading-none tracking-tight">
					<span class="font-light text-white">Resonant</span><span class="font-bold text-emerald-400">OS</span>
				</h1>
				<p class="tagline-text text-zinc-400 mt-6 font-light" style="filter: blur(0px);">
					DAO membership, governance, and co-ownership for ResonantOS
				</p>
			</div>
			
			<!-- Scroll indicator -->
			<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
				<svg class="w-6 h-6 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
				</svg>
			</div>
		</section>

		<!-- Scroll Content Container -->
		<div id="scroll-content" class="relative z-20">

		<!-- What is ResonantOS -->
		<section id="what-is" class="content-section py-12 scroll-mt-[25vh]">
			<div class="glass-banner text-left">
				<div class="banner-content prose-content">
					<h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-8 tracking-tight">What is <span class="gradient-text">ResonantOS</span>?</h2>
					<div class="space-y-6 text-lg text-zinc-300 leading-relaxed">
						<p>
							ResonantOS is becoming a <strong class="color-primary">community-owned system governed through ResonantDAO</strong>. The current foundation is not a liquid token or a transferable badge; it is an official membership layer that DAO smart contracts can verify on-chain.
						</p>
						<p class="text-zinc-400 text-sm mb-6">
							<em>The first implementation focuses on human wallet membership. AI-agent wallets and the Symbiotic Wallet model are intentionally deferred to a later phase.</em>
						</p>
						<ul class="space-y-3 text-zinc-300">
							<li>• <strong class="color-secondary">Manifesto NFT</strong>: Proof that a wallet signed the Augmentatism Manifesto</li>
							<li>• <strong class="color-secondary">Community Member NFT</strong>: The non-transferable DAO access credential</li>
							<li>• <strong class="color-secondary">Symbiotic Licence NFT</strong>: Licence and co-ownership credential for eligible members</li>
							<li>• <strong class="color-secondary">Pioneer NFT</strong>: Capped early-adopter credential for the first 1000 eligible members</li>
						</ul>
						<p class="text-xl font-semibold gradient-text mt-8">
							One Community credential per wallet. Non-transferable. Verifiable by DAO contracts.
						</p>
						<p>
							The NFT is visible, but the official MemberRecord is the source of truth. Other DAO programs verify the record created by the ResonantDAO Membership Program, not the NFT name, image, or metadata.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- The DAO Membership Platform -->
		<section id="economy" class="content-section py-12 scroll-mt-[25vh]">
			<div class="glass-banner text-left">
				<div class="banner-content prose-content">
					<h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-8 tracking-tight">The DAO <span class="gradient-text">Membership</span> Platform</h2>
					<div class="space-y-6 text-lg text-zinc-300 leading-relaxed">
						<p>
							ResonantDAO needs a reliable way to know which wallets belong to the community. The membership layer creates official, non-transferable credentials that become access gates for proposals, contribution records, future governance, and other DAO smart contracts.
						</p>
						
						<div class="component-card my-8">
							<h3 class="text-xl font-semibold mb-4 text-zinc-100">How it works:</h3>
							<ul class="space-y-4 text-zinc-300">
								<li class="flex items-start">
									<span class="color-primary mr-3 mt-1">→</span>
									<span><strong class="color-secondary">Sign the Manifesto.</strong> The wallet signs the canonical Augmentatism Manifesto text or hash.</span>
								</li>
								<li class="flex items-start">
									<span class="color-primary mr-3 mt-1">→</span>
									<span><strong class="color-secondary">Receive official credentials.</strong> The program mints the Manifesto and Community NFTs as soulbound Token-2022 credentials.</span>
								</li>
								<li class="flex items-start">
									<span class="color-primary mr-3 mt-1">→</span>
									<span><strong class="color-secondary">Activate DAO access.</strong> The wallet's MemberRecord becomes the verifiable source of truth for member-gated contracts.</span>
								</li>
								<li class="flex items-start">
									<span class="color-primary mr-3 mt-1">→</span>
									<span><strong class="color-secondary">Build reputation over time.</strong> Contribution, tenure, and domain reputation can grow around one strong wallet instead of many weak ones.</span>
								</li>
							</ul>
						</div>
						
						<p>
							This is the first practical layer of the <strong class="gradient-text">Resonant Economy</strong>: a human-first membership system where contribution and trust matter more than transferable capital.
						</p>
						
						<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
							<div class="emergent-card text-center">
								<div class="mb-3 flex justify-center">
									<svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
									</svg>
								</div>
								<h4 class="font-semibold color-primary mb-2">Official Originals</h4>
								<p class="text-sm text-zinc-400">Fake NFTs cannot create a valid DAO MemberRecord</p>
							</div>
							<div class="emergent-card text-center">
								<div class="mb-3 flex justify-center">
									<svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
								</div>
								<h4 class="font-semibold color-primary mb-2">Soulbound Access</h4>
								<p class="text-sm text-zinc-400">Membership cannot be transferred or sold</p>
							</div>
							<div class="emergent-card text-center">
								<div class="mb-3 flex justify-center">
									<svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
									</svg>
								</div>
								<h4 class="font-semibold color-primary mb-2">DAO Governance</h4>
								<p class="text-sm text-zinc-400">Contribution, reputation, and custodianship over capital alone</p>
							</div>
						</div>
						
						<p class="mt-8 text-zinc-400 italic">
							The Symbiotic Wallet and AI-agent wallets remain part of the roadmap, but they are not part of this first website registration stage.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Comparison Table -->
		<section class="py-20 px-4 sm:px-6 lg:px-8">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl sm:text-5xl font-bold mb-6 tracking-tight">Previous Roadmap vs. Current Focus</h2>
				<p class="text-xl text-zinc-400 mb-12 max-w-3xl">
					<strong class="text-zinc-200">ResonantOS has changed direction.</strong> The older OpenClaw extension and agent marketplace ideas are now secondary to the DAO membership foundation.
				</p>
				
				<div class="grid grid-cols-1 gap-4 mb-8">
					<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
						<h3 class="text-sm font-mono text-blue-400 mb-2 flex items-center gap-2"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> DAO-first</h3>
						<p class="text-zinc-300">membership and access before marketplace features</p>
					</div>
					<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
						<h3 class="text-sm font-mono text-blue-400 mb-2 flex items-center gap-2"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Official credentials</h3>
						<p class="text-zinc-300">originals verified by the DAO program</p>
					</div>
					<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
						<h3 class="text-sm font-mono text-blue-400 mb-2 flex items-center gap-2"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> One member record</h3>
						<p class="text-zinc-300">one active Community credential per wallet</p>
					</div>
					<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
						<h3 class="text-sm font-mono text-blue-400 mb-2 flex items-center gap-2"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Human-first</h3>
						<p class="text-zinc-300">human governance separated from future AI participation</p>
					</div>
				</div>

				<div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6 mb-12">
					<p class="text-lg text-zinc-300 mb-4">
						<strong class="text-zinc-100">Think of it as:</strong> the membership and identity layer that lets the DAO know who can access its contracts. The wallet owns the credentials, but the MemberRecord is the on-chain source of truth.
					</p>
					<p class="text-sm text-zinc-400 mb-4 italic">
						(Future: AI-agent wallets and Symbiotic Wallets can build on this foundation once human membership is stable.)
					</p>
					<div class="space-y-2">
						<p class="text-zinc-400"><strong class="text-zinc-200">First stage:</strong> Manifesto + Community credentials for a human wallet.</p>
						<p class="text-zinc-400"><strong class="text-zinc-200">Later stage:</strong> AI Community Members, Symbiotic Pair Records, and high-trust human+AI workflows.</p>
					</div>
				</div>

				<!-- Comparison Table -->
				<div class="overflow-x-auto">
					<table class="w-full border-collapse">
						<thead>
							<tr class="border-b border-zinc-800">
								<th class="text-left py-4 px-4 text-sm font-mono text-zinc-400">Feature</th>
								<th class="text-center py-4 px-4 text-sm font-mono text-zinc-400">Older Direction</th>
								<th class="text-center py-4 px-4 text-sm font-mono text-zinc-400">Current Direction</th>
							</tr>
						</thead>
						<tbody class="text-sm">
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Primary product focus</td>
								<td class="py-4 px-4 text-center text-green-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Agent tooling</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Manifesto + Community issuance</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Identity model</td>
								<td class="py-4 px-4 text-center text-green-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> App accounts</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> One member record per wallet</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Transferability</td>
								<td class="py-4 px-4 text-center text-green-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Not defined</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Non-transferable credentials</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Source of truth</td>
								<td class="py-4 px-4 text-center text-green-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Metadata and app state</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> On-chain MemberRecord</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Manifesto credential</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> None</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Required before membership</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Community membership</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> None</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> DAO access credential</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Symbiotic Licence</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> Not defined</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Community members only</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">AI wallet model</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> None</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Later phase</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Symbiotic Wallet</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> None</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Deferred</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">DAO governance</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> None</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Contribution and custodians</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Pioneer credential</td>
								<td class="py-4 px-4 text-center text-zinc-600"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> None</span></td>
								<td class="py-4 px-4 text-center text-blue-400"><span class="inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> First 1000 eligible members</span></td>
							</tr>
							<tr class="border-b border-zinc-800/50">
								<td class="py-4 px-4 text-zinc-300">Installation</td>

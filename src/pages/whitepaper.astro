		<script>
			// @ts-nocheck
			import Lenis from 'lenis';
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			gsap.registerPlugin(ScrollTrigger);

			// Initialize Lenis smooth scroll
			const lenis = new Lenis({
				duration: 1.2,
				easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
			});

			function raf(time: number) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}
			requestAnimationFrame(raf);

			lenis.on('scroll', ScrollTrigger.update);
			gsap.ticker.add((time: number) => lenis.raf(time * 1000));
			gsap.ticker.lagSmoothing(0);

			// Background blur on scroll
			const backgroundContainer = document.getElementById('background-container');
			if (backgroundContainer) {
				gsap.to(backgroundContainer, {
					scrollTrigger: {
						trigger: document.body,
						start: 'top top',
						end: 'bottom bottom',
						scrub: 1,
					},
					filter: 'blur(40px)',
					opacity: 0.3,
				});
			}

			// Content sections reveal
			const sections = document.querySelectorAll('.content-section');
			sections.forEach((section) => {
				ScrollTrigger.create({
					trigger: section,
					start: 'top 80%',
					onEnter: () => section.classList.add('visible'),
				});
			});

			// Seasonal orb animations
			const orb1 = document.querySelector('.gradient-orb-1');
			const orb2 = document.querySelector('.gradient-orb-2');
			const orb3 = document.querySelector('.gradient-orb-3');
			const orb4 = document.querySelector('.gradient-orb-4');
			
			const vw = window.innerWidth;
			const vh = window.innerHeight;
			
			function createSeasonalTimeline(orb, movement, autumnGradient) {
				const timeline = gsap.timeline({
					scrollTrigger: {
						trigger: document.body,
						start: 'top top',
						end: 'bottom bottom',
						scrub: 1.5,
					}
				});
				
				timeline.to(orb, {
					...movement,
					backgroundImage: autumnGradient,
				});
				
				return timeline;
			}
			
			if (orb1) {
				createSeasonalTimeline(
					orb1,
					{ x: vw * 0.8, y: vh * 0.9, rotation: 180, scale: 0.7 },
					'linear-gradient(135deg, #d97706, #92400e)'
				);
			}
			
			if (orb2) {
				createSeasonalTimeline(
					orb2,
					{ x: vw * -0.7, y: vh * -0.8, rotation: -120, scale: 1.4 },
					'linear-gradient(135deg, #b45309, #78350f)'
				);
			}
			
			if (orb3) {
				createSeasonalTimeline(
					orb3,
					{ x: vw * -0.5, y: vh * 0.6, rotation: 90, scale: 0.5 },
					'linear-gradient(135deg, #ea580c, #9a3412)'
				);
			}
			
			if (orb4) {
				createSeasonalTimeline(
					orb4,
					{ x: vw * 0.7, y: vh * -0.6, rotation: 150, scale: 1.5 },
					'linear-gradient(135deg, #a16207, #713f12)'
				);
			}
		</script>

---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="Augmentatism Manifesto NFT - ResonantOS" description="The Augmentatism Manifesto NFT records a wallet's agreement to the philosophical foundation of ResonantDAO membership.">
	<section class="px-4 pb-16 pt-14 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-5xl">
			<p class="mb-5 font-mono text-sm uppercase tracking-widest text-emerald-400">Manifesto</p>
			<h1 class="text-5xl font-bold leading-tight tracking-tight sm:text-6xl">Membership begins with agreement.</h1>
			<p class="mt-8 max-w-3xl text-xl leading-8 text-zinc-300">
				The Augmentatism Manifesto NFT is proof that a wallet signed the canonical manifesto. It is the philosophical prerequisite for Community membership.
			</p>
			<div class="mt-10 flex flex-col gap-4 sm:flex-row">
				<a href="https://augmentatism.com/" target="_blank" rel="noopener noreferrer" class="rounded-md bg-emerald-600 px-6 py-3 text-center font-semibold text-white transition-colors hover:bg-emerald-500">Read the Manifesto</a>
				<a href="/membership" class="rounded-md border border-white/15 px-6 py-3 text-center font-semibold text-zinc-100 transition-colors hover:border-emerald-400/70">Membership Flow</a>
			</div>
		</div>
	</section>

	<section class="px-4 py-12 sm:px-6 lg:px-8">
		<div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-3">
			<div class="rounded-lg border border-white/10 bg-white/[0.03] p-6">
				<h2 class="text-xl font-semibold">Wallet Signature</h2>
				<p class="mt-3 text-zinc-400">The user signs the canonical Manifesto text or hash with their wallet.</p>
			</div>
			<div class="rounded-lg border border-white/10 bg-white/[0.03] p-6">
				<h2 class="text-xl font-semibold">Non-Transferable Proof</h2>
				<p class="mt-3 text-zinc-400">The credential is minted to the wallet as a soulbound Token-2022 NFT.</p>
			</div>
			<div class="rounded-lg border border-white/10 bg-white/[0.03] p-6">
				<h2 class="text-xl font-semibold">Community Dependency</h2>
				<p class="mt-3 text-zinc-400">The Community Member credential is valid because Manifesto agreement is recorded in the same membership record.</p>
			</div>
		</div>
	</section>
</BaseLayout>
